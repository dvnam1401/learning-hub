# === BẮT BUỘC (local + production) ===
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai-32-ky-tu

# === LOCAL DEV (mặc định dùng SQLite data/app.db — KHÔNG cần Cloudflare) ===
# Chỉ cần JWT_SECRET + GOOGLE_* nếu muốn xem video.
# Sau khi đổi Node.js: chạy npm rebuild better-sqlite3

# === GOOGLE DRIVE — để phát video /api/videos/[fileId]/stream ===
# Lấy từ project drive_scaner (cùng token đã scan Shared Drive):
#   GOOGLE_CLIENT_ID     = credentials.json → installed.client_id
#   GOOGLE_CLIENT_SECRET = credentials.json → installed.client_secret
#   GOOGLE_REFRESH_TOKEN = token.json → refresh_token
# OAuth scope bắt buộc: https://www.googleapis.com/auth/drive.readonly
# Token cần quyền XEM video trên Drive (drive.readonly). Không cần quyền tải xuống.
# Phát video: dùng get_video_info → videoplayback (giống player Drive / DevTools), không dùng alt=media.
# Tùy chọn: npm run cache:videos nếu có quyền tải (lưu data/video-cache/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === CLOUDFLARE D1 — CHỈ khi deploy production (Vercel), bỏ trống khi dev local ===
# Tạo D1 trên Cloudflare Dashboard → lấy database_id
# API Token: quyền Account → D1 → Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# === Build catalog (npm run build:catalog) ===
DRIVE_NDJSON_PATH=../drive_scaner/output/drive.ndjson
